{
    "name": "tryhackx/flarum-advanced-pages",
    "description": "Create advanced custom pages with HTML, BBCode, Markdown, PHP, or plain text content types for Flarum.",
    "keywords": [
        "flarum",
        "pages",
        "custom-pages",
        "html",
        "bbcode",
        "markdown",
        "php",
        "cms"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "TryHackX",
            "email": "contact@tryhackx.org",
            "homepage": "https://github.com/TryHackX"
        }
    ],
    "support": {
        "issues": "https://github.com/TryHackX/flarum-advanced-pages/issues",
        "source": "https://github.com/TryHackX/flarum-advanced-pages"
    },
    "require": {
        "php": "^8.1",
        "flarum/core": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "TryHackX\\AdvancedPages\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Advanced Pages",
            "category": "feature",
            "icon": {
                "name": "fas fa-file-code",
                "color": "#fff",
                "backgroundColor": "#4a90d9"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}